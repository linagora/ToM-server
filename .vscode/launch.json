{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug tom-server with Nx",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nx", "serve", "tom-server", "--no-tui"],
      "env": {
        "NODE_OPTIONS": "--inspect=0"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/dist/apps/tom-server/**/*.(m|c|)js",
        "${workspaceFolder}/packages/**/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    }
  ]
}
