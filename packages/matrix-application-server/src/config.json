{
  "base_url": {
    "type": "string",
    "default": "http://localhost:3000"
  },
  "sender_localpart": {
    "type": "string",
    "default": "twake"
  },
  "registration_file_path": {
    "type": "string",
    "default": "registration.yaml"
  },
  "namespaces": {
    "type": "object",
    "default": {
      "users": []
    }
  },
  "push_ephemeral": {
    "type": "boolean",
    "default": true
  },
  "rate_limiting_window": {
    "type": "number",
    "default": 600000
  },
  "rate_limiting_nb_requests": {
    "type": "number",
    "default": 100
  },
  "trust_x_forwarded_for": {
    "type": "boolean",
    "default": false
  }
}
