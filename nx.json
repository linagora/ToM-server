{
  "defaultBase": "dev",
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [],
    "production": [
      "default"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ]
    },
    "test": {
      "cache": true,
      "dependsOn": [
        "^build",
        "^test"
      ]
    },
    "check": {
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.js",
        "{projectRoot}/**/*.jsx",
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{workspaceRoot}/biome.json"
      ]
    },
    "dev": {
      "dependsOn": []
    }
  },
  "useInferencePlugins": false,
  "nxCloudId": "67a2162cb7a06c469a8df1a3",
  "analytics": false
}
