    "jest": "^29.5.0",
    "jest-environment-node": "^29.7.0",
    "jest-util": "^29.7.0",
    "js-nacl": "^1.4.0",
    "ldapjs": "^2.3.3",
    "lerna": "^9.0.7",
    "moment": "^2.29.4",
    "node-fetch": "^3.3.0",
    "node-fetch-jest": "npm:node-fetch@^2.6.9",
    "nodemon": "^3.1.10",
    "nx": "22.6.1",
    "react-refresh": "^0.10.0",
    "rimraf": "^4.3.1",
    "rollup": "^3.18.0",
    "rollup-plugin-cleaner": "^1.0.0",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.2.8",
